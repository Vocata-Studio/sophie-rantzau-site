<section class="contact" id="kontakt">
  <div class="wrap">
    <span class="eyebrow contact-eyebrow">
      <span data-da>Kontakt</span>
      <span data-en>Contact</span>
    </span>

    <div class="contact-grid">

    <!-- Left col -->
    <div class="contact-left">
      <h2 class="display contact-headline" data-da>
        Lad os tage<br /><em>en samtale.</em>
      </h2>
      <h2 class="display contact-headline" data-en>
        Let's have<br /><em>a conversation.</em>
      </h2>

      <p class="contact-lede" data-da>
        Skriv et par linjer om, hvad du står med — så vender jeg tilbage hurtigst muligt.
      </p>
      <p class="contact-lede" data-en>
        Write a few lines about where you are right now — I'll get back to you as soon as I can.
      </p>

      <a href="https://cal.eu/sophie-rantzau/free-discovery-call" target="_blank" rel="noopener" class="btn btn-primary contact-cal">
        <span data-da>Book gratis intro-samtale</span>
        <span data-en>Book Free Discovery Call</span>
        <span class="arr">&rarr;</span>
      </a>

      <dl class="contact-details">
        <div class="contact-row">
          <dt data-da>Telefon</dt>
          <dt data-en>Phone</dt>
          <dd><a href="tel:+4530880828">+45 30 88 08 28</a></dd>
        </div>
        <div class="contact-row">
          <dt>Email</dt>
          <dd><a href="mailto:hej@sophierantzau.dk">hej@sophierantzau.dk</a></dd>
        </div>
        <div class="contact-row">
          <dt data-da>Adresse</dt>
          <dt data-en>Address</dt>
          <dd>
            <span data-da>Nykøbing Mors, Danmark</span>
            <span data-en>Nykøbing Mors, Denmark</span>
          </dd>
        </div>
        <div class="contact-row">
          <dt>Social</dt>
          <dd class="contact-social">
            <a href="#" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="#" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          </dd>
        </div>
      </dl>
    </div>

    <!-- Right col: form -->
    <div class="contact-form-wrap">
      <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="contact-form-row contact-form-row--2col">
          <div class="contact-field">
            <label for="cf-navn" data-da>Navn</label>
            <label for="cf-navn" data-en>Name</label>
            <input id="cf-navn" type="text" name="navn" autocomplete="name" required />
          </div>
          <div class="contact-field">
            <label for="cf-email">Email</label>
            <input id="cf-email" type="email" name="email" autocomplete="email" required />
          </div>
        </div>

        <div class="contact-field">
          <label for="cf-telefon" data-da>Telefon <span class="field-opt">(valgfri)</span></label>
          <label for="cf-telefon" data-en>Phone <span class="field-opt">(optional)</span></label>
          <input id="cf-telefon" type="tel" name="telefon" autocomplete="tel" />
        </div>

        <div class="contact-field">
          <label for="cf-besked" data-da>Besked</label>
          <label for="cf-besked" data-en>Message</label>
          <textarea id="cf-besked" name="besked" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary contact-submit">
          <span data-da>Send besked</span>
          <span data-en>Send message</span>
          <span class="arr">&rarr;</span>
        </button>
      </form>
    </div>

    </div><!-- /.contact-grid -->
  </div><!-- /.wrap -->
</section>
