---
interface Props {
  size?: 'default' | 'lg';
}

const { size = 'default' } = Astro.props;
---

<a href="#" class:list={['logo', { 'logo--lg': size === 'lg' }]} aria-label="Sophie Rantzau">
  <span class="logo-name">Sophie Rantzau</span>
  <!-- bridge-line: single arch with piers -->
  <span class="logo-bridge logo-bridge--bridge-line" aria-hidden="true">
    <svg viewBox="0 0 240 36" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <line x1="4" y1="20" x2="236" y2="20" vector-effect="non-scaling-stroke"/>
      <path d="M 78 20 Q 120 0 162 20"/>
      <line x1="78"  y1="20" x2="78"  y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="162" y1="20" x2="162" y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="44"  y1="20" x2="44"  y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="196" y1="20" x2="196" y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="0" y1="34" x2="240" y2="34" stroke-dasharray="1 4" opacity="0.6" vector-effect="non-scaling-stroke"/>
    </svg>
  </span>
  <!-- line-flat: straight deck with evenly spaced piers -->
  <span class="logo-bridge logo-bridge--line-flat" aria-hidden="true">
    <svg viewBox="0 0 240 36" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <line x1="4" y1="20" x2="236" y2="20" vector-effect="non-scaling-stroke"/>
      <line x1="40"  y1="20" x2="40"  y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="80"  y1="20" x2="80"  y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="120" y1="20" x2="120" y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="160" y1="20" x2="160" y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="200" y1="20" x2="200" y2="30" vector-effect="non-scaling-stroke"/>
      <line x1="0" y1="34" x2="240" y2="34" stroke-dasharray="1 4" opacity="0.6" vector-effect="non-scaling-stroke"/>
    </svg>
  </span>
  <!-- sallingsund: flat deck on arches -->
  <span class="logo-bridge logo-bridge--sallingsund" aria-hidden="true">
    <svg viewBox="0 0 240 32" preserveAspectRatio="none" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
      <path fill="currentColor" stroke="none" d="
        M 0 6 L 240 6 L 240 11
        Q 220 6 200 11
        Q 180 6 160 11
        Q 140 6 120 11
        Q 100 6 80 11
        Q 60 6 40 11
        Q 20 6 0 11 Z"/>
      <g stroke-width="2.6">
        <line x1="0"   y1="11" x2="0"   y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="40"  y1="11" x2="40"  y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="80"  y1="11" x2="80"  y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="120" y1="11" x2="120" y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="160" y1="11" x2="160" y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="200" y1="11" x2="200" y2="27" vector-effect="non-scaling-stroke"/>
        <line x1="240" y1="11" x2="240" y2="27" vector-effect="non-scaling-stroke"/>
      </g>
      <line x1="0" y1="30" x2="240" y2="30" stroke-dasharray="1 4" opacity="0.6" vector-effect="non-scaling-stroke"/>
    </svg>
  </span>
</a>
